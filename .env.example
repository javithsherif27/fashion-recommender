# Optional. Leave unset to run the app fully locally.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
USE_LLM=auto
# Set true on AWS when OpenAI must be used instead of local interpretation fallback.
REQUIRE_OPENAI=false

# Index and embedding settings.
INDEX_DIR=data/index
EMBEDDING_BACKEND=auto
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
